{
  "version": 2,
  "public": true,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_SOCKET_URL": "https://texas-holdem-api.up.railway.app"
  }
}
